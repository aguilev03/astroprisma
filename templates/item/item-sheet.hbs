<section class="astroprisma-item-sheet">
	<header class="astroprisma-header">
		<div class="astroprisma-field astroprisma-field-wide">
			<label>Name</label>
			<input type="text" name="name" value="{{document.name}}" />
		</div>
		<div class="astroprisma-field">
			<label>Type</label>
			<input type="text" value="{{document.type}}" disabled />
		</div>
		<div class="astroprisma-field">
			<label>Equipped</label>
			<label class="astroprisma-checkbox">
				<input type="checkbox" name="system.equipped" {{checked system.equipped}} />
				<span>Active</span>
			</label>
		</div>
	</header>

	<section class="astroprisma-panel astroprisma-grid astroprisma-grid-2">
		{{#if isWeapon}}
		<div class="astroprisma-field">
			<label>Damage Die</label>
			<input type="text" name="system.damageDie" value="{{system.damageDie}}" />
		</div>
		<div class="astroprisma-field">
			<label>Stat</label>
			<select name="system.stat">
				{{#each statOptions}}
				<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
				{{/each}}
			</select>
		</div>
		<div class="astroprisma-field astroprisma-field-wide">
			<label>Mods</label>
			<input type="text" name="system.modsText" value="{{modsString}}" placeholder="Comma-separated weapon mod IDs or names" />
		</div>
		{{/if}}

		{{#if isWeaponMod}}
		<div class="astroprisma-field">
			<label>Damage Bonus Formula</label>
			<input type="text" name="system.damageBonusFormula" value="{{system.damageBonusFormula}}" placeholder="+1, +1d4" />
		</div>
		<div class="astroprisma-field">
			<label>Stat Override</label>
			<select name="system.statOverride">
				{{#each overrideOptions}}
				<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
				{{/each}}
			</select>
		</div>
		<div class="astroprisma-field astroprisma-field-wide">
			<label>Effect Notes</label>
			<input type="text" name="system.effectNotes" value="{{system.effectNotes}}" />
		</div>
		{{/if}}
	</section>

	<section class="astroprisma-panel astroprisma-card">
		<label>Description</label>
		<textarea name="system.description" rows="10">{{system.description}}</textarea>
	</section>
</section>
