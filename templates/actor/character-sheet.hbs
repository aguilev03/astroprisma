<section class="character-sheet">
	<header class="sheet-header astroprisma-header">
		<div class="astroprisma-field astroprisma-field-wide">
			<label>Name</label>
			<input type="text" name="name" value="{{document.name}}" />
		</div>
		<div class="astroprisma-field">
			<label>Origin</label>
			<input type="text" name="system.origin" value="{{system.origin}}" />
		</div>
		<div class="astroprisma-field">
			<label>Health</label>
			<div class="astroprisma-meter">
				<input type="number" name="system.health.value" value="{{system.health.value}}" min="0" />
				<span>/</span>
				<input type="number" name="system.health.max" value="{{system.health.max}}" min="0" />
			</div>
		</div>
		<div class="astroprisma-field">
			<label>Energy</label>
			<div class="astroprisma-meter">
				<input type="number" name="system.energy.value" value="{{system.energy.value}}" min="0" />
				<span>/</span>
				<input type="number" name="system.energy.max" value="{{system.energy.max}}" min="0" />
			</div>
		</div>
		<div class="astroprisma-field">
			<label>Armor</label>
			<input type="number" name="system.armor" value="{{system.armor}}" min="0" />
		</div>
		<div class="astroprisma-field">
			<label>EXP</label>
			<input type="number" name="system.exp" value="{{system.exp}}" min="0" />
		</div>
		<div class="astroprisma-field">
			<label>Hyperdrive</label>
			<input type="number" name="system.hyperdrive" value="{{system.hyperdrive}}" min="0" />
		</div>
	</header>

	<nav class="astroprisma-tabs">
		<button type="button" data-action="setTab" data-tab="stats" class="{{#if tabState.stats}}is-active{{/if}}">Stats</button>
		<button type="button" data-action="setTab" data-tab="weapons" class="{{#if tabState.weapons}}is-active{{/if}}">Weapons</button>
		<button type="button" data-action="setTab" data-tab="inventory" class="{{#if tabState.inventory}}is-active{{/if}}">Inventory</button>
		<button type="button" data-action="setTab" data-tab="cybertech" class="{{#if tabState.cybertech}}is-active{{/if}}">Talents</button>
		<button type="button" data-action="setTab" data-tab="memory" class="{{#if tabState.memory}}is-active{{/if}}">Abilities</button>
		<button type="button" data-action="setTab" data-tab="notes" class="{{#if tabState.notes}}is-active{{/if}}">Notes</button>
	</nav>

	{{#if tabState.stats}}
	<section class="astroprisma-panel astroprisma-grid astroprisma-grid-2">
		<div class="astroprisma-card">
			<h2>Attributes</h2>
			<div class="astroprisma-attribute-row">
				<label>Vigor</label>
				<input type="number" name="system.attributes.vigor" value="{{system.attributes.vigor}}" min="0" />
				<button type="button" data-action="rollAttribute" data-attribute="vigor">Roll</button>
			</div>
			<div class="astroprisma-attribute-row">
				<label>Grace</label>
				<input type="number" name="system.attributes.grace" value="{{system.attributes.grace}}" min="0" />
				<button type="button" data-action="rollAttribute" data-attribute="grace">Roll</button>
			</div>
			<div class="astroprisma-attribute-row">
				<label>Mind</label>
				<input type="number" name="system.attributes.mind" value="{{system.attributes.mind}}" min="0" />
				<button type="button" data-action="rollAttribute" data-attribute="mind">Roll</button>
			</div>
			<div class="astroprisma-attribute-row">
				<label>Tech</label>
				<input type="number" name="system.attributes.tech" value="{{system.attributes.tech}}" min="0" />
				<button type="button" data-action="rollAttribute" data-attribute="tech">Roll</button>
			</div>
		</div>

		<div class="astroprisma-card">
			<h2>Status Conditions</h2>
			<label class="astroprisma-checkbox"><input type="checkbox" name="system.conditions.stun" {{checked system.conditions.stun}} /> Stun</label>
			<label class="astroprisma-checkbox"><input type="checkbox" name="system.conditions.breach" {{checked system.conditions.breach}} /> Breach</label>
			<label class="astroprisma-checkbox"><input type="checkbox" name="system.conditions.shock" {{checked system.conditions.shock}} /> Shock</label>
			<label class="astroprisma-checkbox"><input type="checkbox" name="system.conditions.silence" {{checked system.conditions.silence}} /> Silence</label>
			<label class="astroprisma-checkbox"><input type="checkbox" name="system.conditions.immunity" {{checked system.conditions.immunity}} /> Immunity</label>
			<label class="astroprisma-checkbox"><input type="checkbox" name="system.conditions.overheat" {{checked system.conditions.overheat}} /> Overheat</label>

			<div class="astroprisma-field">
				<label>Memory Slots</label>
				<input type="number" name="system.memorySlots" value="{{system.memorySlots}}" min="0" />
			</div>
		</div>
	</section>
	{{/if}}

	{{#if tabState.weapons}}
	<section class="astroprisma-panel astroprisma-card">
		<h2>Weapons</h2>
		<ul class="astroprisma-item-list astroprisma-item-cards">
			{{#each weaponItems}}
			<li class="astroprisma-item-row">
				<div>
					<strong>{{name}}</strong>
					<div class="astroprisma-item-meta">Damage {{system.damage}}{{#if system.range}} | Range {{system.range}}{{/if}}{{#if system.attackBonus}} | ATK +{{system.attackBonus}}{{/if}}</div>
				</div>
				<div class="astroprisma-item-controls">
					<button type="button" data-action="rollItemAttack" data-item-id="{{id}}">Attack</button>
					<button type="button" data-action="rollItemDamage" data-item-id="{{id}}">Damage</button>
					<button type="button" data-action="toggleEquip" data-item-id="{{id}}">{{#if system.equipped}}Unequip{{else}}Equip{{/if}}</button>
					<button type="button" data-action="deleteItem" data-item-id="{{id}}">Delete</button>
				</div>
			</li>
			{{else}}
			<li>No weapon items yet.</li>
			{{/each}}
		</ul>
		<label>Weapon Notes</label>
		<textarea name="system.weapons" rows="8">{{system.weapons}}</textarea>
	</section>
	{{/if}}

	{{#if tabState.inventory}}
	<section class="astroprisma-panel astroprisma-card">
		<h2>Inventory</h2>
		<ul class="astroprisma-item-list astroprisma-item-cards">
			{{#each inventoryItems}}
			<li class="astroprisma-item-row">
				<div>
					<strong>{{name}}</strong>
					<div class="astroprisma-item-meta">{{typeLabel}} | Qty {{system.quantity}}{{#if system.defenseBonus}} | DEF +{{system.defenseBonus}}{{/if}}{{#if system.weight}} | Wt {{system.weight}}{{/if}}</div>
				</div>
				<div class="astroprisma-item-controls">
					{{#if isConsumable}}
					<button type="button" data-action="useConsumable" data-item-id="{{id}}">Use</button>
					{{/if}}
					<button type="button" data-action="toggleEquip" data-item-id="{{id}}">{{#if system.equipped}}Unequip{{else}}Equip{{/if}}</button>
					<button type="button" data-action="deleteItem" data-item-id="{{id}}">Delete</button>
				</div>
			</li>
			{{else}}
			<li>No inventory items yet.</li>
			{{/each}}
		</ul>
		<label>Inventory Notes</label>
		<textarea name="system.inventory" rows="8">{{system.inventory}}</textarea>
	</section>
	{{/if}}

	{{#if tabState.cybertech}}
	<section class="astroprisma-panel astroprisma-card">
		<h2>Talents</h2>
		<ul class="astroprisma-item-list astroprisma-item-cards">
			{{#each talentItems}}
			<li class="astroprisma-item-row">
				<div>
					<strong>{{name}}</strong>
					<div class="astroprisma-item-meta">{{system.description}}</div>
				</div>
				<div class="astroprisma-item-controls">
					<button type="button" data-action="toggleEquip" data-item-id="{{id}}">{{#if system.equipped}}Unequip{{else}}Equip{{/if}}</button>
					<button type="button" data-action="deleteItem" data-item-id="{{id}}">Delete</button>
				</div>
			</li>
			{{else}}
			<li>No talent items yet.</li>
			{{/each}}
		</ul>
		<label>Talent Notes</label>
		<textarea name="system.cybertech" rows="8">{{system.cybertech}}</textarea>
	</section>
	{{/if}}

	{{#if tabState.memory}}
	<section class="astroprisma-panel astroprisma-card">
		<h2>Abilities</h2>
		<ul class="astroprisma-item-list astroprisma-item-cards">
			{{#each abilityItems}}
			<li class="astroprisma-item-row">
				<div>
					<strong>{{name}}</strong>
					<div class="astroprisma-item-meta">{{system.description}}</div>
				</div>
				<div class="astroprisma-item-controls">
					<button type="button" data-action="toggleEquip" data-item-id="{{id}}">{{#if system.equipped}}Unequip{{else}}Equip{{/if}}</button>
					<button type="button" data-action="deleteItem" data-item-id="{{id}}">Delete</button>
				</div>
			</li>
			{{else}}
			<li>No ability items yet.</li>
			{{/each}}
		</ul>
	</section>
	{{/if}}

	{{#if tabState.notes}}
	<section class="astroprisma-panel astroprisma-card">
		<h2>Notes</h2>
		<textarea name="system.notes" rows="12">{{system.notes}}</textarea>
	</section>
	{{/if}}
</section>
